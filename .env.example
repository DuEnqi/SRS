# ‼️ ‼️ Important Note before using the api
# - Never use api_key directly in the codebase
# - Use environment variables (env) for secrets
#
# --- Option A: Azure OpenAI (openagents) ---
# Endpoint: https://openagents.openai.azure.com/openai/responses?api-version=2025-04-01-preview
# SDK base_url: https://openagents.openai.azure.com/openai/v1/
# Get key from Azure portal -> openagents resource -> Keys and Endpoint
#
# LLM_PROVIDER=azure
# AZURE_OPENAI_ENDPOINT=https://openagents.openai.azure.com
# AZURE_OPENAI_API_VERSION=2025-04-01-preview
# AZURE_OPENAI_API_KEY=
# OPENAI_API_BASE=https://openagents.openai.azure.com/openai/v1/
# JUDGE_MODEL=gpt-4o-mini   # your deployment name
#
# --- Option B: yunwu.ai relay ---
# OPENAI_API_KEY=
# OPENAI_API_BASE=https://yunwu.ai/v1
# STALE_MODEL=gpt-4o-mini

LLM_PROVIDER=azure
AZURE_OPENAI_ENDPOINT=https://openagents.openai.azure.com
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_API_KEY=
OPENAI_API_BASE=https://openagents.openai.azure.com/openai/v1/
OPENAI_BASE_URL=https://openagents.openai.azure.com/openai/v1/

STALE_MODEL=gpt-4o-mini
JUDGE_MODEL=gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini
TARGET_MODEL=gpt-4o-mini
